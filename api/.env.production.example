# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/quiero-menu?retryWrites=true&w=majority

# JWT (generate strong secrets: openssl rand -hex 32)
JWT_SECRET=generate-a-strong-secret-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=generate-another-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
FRONTEND_URL=https://quiero.menu
ALLOWED_ORIGINS=https://quiero.menu,https://www.quiero.menu

# OpenAI (menu AI builder)
OPENAI_API_KEY=sk-proj-...

# Lemon Squeezy (billing)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_VARIANT_PRO=

# AWS (SES emails - uses IAM role from EC2, no keys needed)
AWS_SES_REGION=us-east-1
SES_FROM_EMAIL=no-reply@quiero.menu
SES_REPLY_TO_EMAIL=contact@quiero.menu

# AWS S3 (images - uses IAM role from EC2, no keys needed)
S3_BUCKET=quiero-menu-images
S3_REGION=us-east-1
CLOUDFRONT_DOMAIN=dxxxxxxxxx.cloudfront.net
